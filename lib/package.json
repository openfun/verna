{
  "name": "@openfun/verna",
  "version": "1.0.0-beta.1",
  "private": false,
  "keywords": [
    "react",
    "form",
    "json-schema"
  ],
  "description": "An extensible form builder based on React JSON Schema Form.",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "yarn build:dev",
    "build:dev": "vite build --watch --logLevel warn --mode development --config ./vite.dev.config.ts",
    "i18n:extract": "yarn formatjs extract --id-interpolation-pattern '[sha512:contenthash:base64:6]' --format crowdin './src/**/*.ts*' --ignore './src/**/*.spec.ts*' --out-file './i18n/frontend.json'",
    "i18n:compile": "yarn formatjs compile-folder --format crowdin ./i18n/locales ./src/translations",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "test": "jest"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./*": "./*",
    "./package.json": "./package.json"
  },
  "repository": "https://github.com/openfun/verna",
  "author": {
    "name": "Open FUN (France Université Numérique)",
    "email": "fun.dev@fun-mooc.fr"
  },
  "bugs": {
    "url": "https://github.com/openfun/verna/issues"
  },
  "browserslist": [
    "last 2 versions",
    ">1%",
    "not dead"
  ],
  "license": "MIT",
  "dependencies": {
    "@rjsf/core": "5.18.1",
    "json-schema": "0.4.0",
    "lodash": "4.17.21",
    "uuid": "9.0.1"
  },
  "peerDependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-intl": "6.6.4"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@babel/core": "7.24.3",
    "@babel/preset-env": "7.24.3",
    "@babel/preset-react": "7.24.1",
    "@babel/preset-typescript": "7.24.1",
    "@formatjs/cli": "6.2.9",
    "@testing-library/dom": "9.3.4",
    "@testing-library/jest-dom": "6.4.2",
    "@testing-library/react": "14.2.2",
    "@testing-library/user-event": "14.5.2",
    "@types/jest": "29.5.12",
    "@types/lodash": "4.17.0",
    "@types/react": "18.2.73",
    "@types/react-dom": "18.2.22",
    "@types/uuid": "9.0.8",
    "@typescript-eslint/eslint-plugin": "7.4.0",
    "@typescript-eslint/parser": "7.4.0",
    "@vitejs/plugin-react": "4.2.1",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-import-resolver-typescript": "3.6.1",
    "eslint-plugin-compat": "4.2.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-jsx-a11y": "6.8.0",
    "eslint-plugin-prettier": "5.1.3",
    "eslint-plugin-react": "7.34.1",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "prettier": "3.2.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-intl": "6.6.4",
    "rollup": "4.13.1",
    "tslib": "2.6.2",
    "typescript": "4.8.4",
    "vite": "5.2.6",
    "vite-plugin-dts": "3.8.1"
  }
}
